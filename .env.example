# Labely 环境配置文件
# 复制此文件为 .env 并修改配置

# ==================== Label Studio 配置 ====================
LABEL_STUDIO_HOST=0.0.0.0
LABEL_STUDIO_PORT=8080

# Label Studio API Key (在 Label Studio 中生成)
# LABEL_STUDIO_API_KEY=your_api_key_here

# ==================== 数据库配置 ====================
POSTGRES_DB=labelstudio
POSTGRES_USER=labelstudio
POSTGRES_PASSWORD=labelstudio

# ==================== SAM3 Backend 配置 ====================
SAM3_BACKEND_HOST=0.0.0.0
SAM3_BACKEND_PORT=9090

# SAM3 默认文本提示 (用于自动分割)
DEFAULT_PROMPT=object

# ==================== Hugging Face 配置 ====================
# HF Token (用于下载模型，支持多种配置方式)
# 方式1: 直接设置 token
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# 方式2: 从文件读取 (推荐，更安全)
# HF_TOKEN_FILE=/run/secrets/hf_token

# 方式3: 使用宿主机的 HF 缓存目录 (自动读取已登录的 token)
# 设置为 true 会挂载 ~/.cache/huggingface 目录
HF_USE_HOST_CACHE=true

# HF 缓存目录 (宿主机路径，用于挂载)
# HF_HOST_CACHE=~/.cache/huggingface

# ==================== 通用配置 ====================
# 运行设备: cuda:0, cuda:1, cpu
DEVICE=cuda:0

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ML Backend 超时设置 (秒)
ML_TIMEOUT_SETUP=120
ML_TIMEOUT_PREDICT=120
